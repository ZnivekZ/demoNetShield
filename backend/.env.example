# NetShield Dashboard - Environment Variables
# ================================================
# Copy this file to .env and fill in real values

# MikroTik CHR API
MIKROTIK_HOST=192.168.100.118
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=nivek

# Wazuh SIEM API
WAZUH_HOST=100.90.106.121
WAZUH_PORT=55000
WAZUH_USER=admin
WAZUH_PASSWORD=admin

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Database (SQLite for lab, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./netshield.db

# Redis (optional - system works without it)
REDIS_URL=redis://localhost:6379

# App Settings
APP_ENV=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# GLPI (Asset Management / Inventario)
GLPI_URL=http://glpi.facultad.local
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=
GLPI_VERIFY_SSL=false

# ── Mock Mode ───────────────────────────────────────────────────────────────
# Activa datos simulados sin necesitar sistemas externos corriendo.
#
# Modos disponibles:
#   MOCK_ALL=true        → todos los servicios en mock (modo demo completo)
#   MOCK_MIKROTIK=true   → solo MikroTik en mock, el resto real
#   MOCK_WAZUH=true      → solo Wazuh en mock, el resto real
#   MOCK_GLPI=true       → solo GLPI en mock, el resto real
#   MOCK_ANTHROPIC=true  → solo Anthropic en mock, el resto real
#
# Combinación: MOCK_ALL activa todo; los flags individuales son OR sobre MOCK_ALL.
# Híbrido: MOCK_ALL=false + MOCK_GLPI=true → GLPI mock, MikroTik/Wazuh reales.
#
# Retrocompat: APP_ENV=lab sin ninguna variable MOCK_* definida = MOCK_ALL=true
# Para usar APP_ENV=lab con servicios reales: agregar MOCK_ALL=false explícitamente.
#
MOCK_ALL=false
# MOCK_MIKROTIK=false
# MOCK_WAZUH=false
# MOCK_GLPI=false
# MOCK_ANTHROPIC=false
