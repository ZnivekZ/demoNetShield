        },
        {
          "name": "Última alerta crítica",
          "request": { "method": "GET", "url": "{{base_url}}/api/wazuh/alerts/last-critical" }
        },
        {
          "name": "MITRE ATT&CK resumen",
          "request": { "method": "GET", "url": "{{base_url}}/api/wazuh/mitre/summary" }
        },
        {
          "name": "Health Wazuh",
          "request": { "method": "GET", "url": "{{base_url}}/api/wazuh/health" }
        },
        {
          "name": "Active Response",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/wazuh/active-response",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"command\": \"restart-wazuh\", \"agent_id\": \"004\"}"
            }
          }
        },
        {
          "name": "WS: Alertas en tiempo real",
          "request": {
            "method": "GET",
            "url": "{{ws_url}}/ws/alerts",
            "description": "WebSocket. Emite cada 5s si hay alertas nuevas: {type:'alerts', data:{alerts:[...]}}"
          }
        }
      ]
    },

