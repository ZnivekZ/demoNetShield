{
  "info": {
    "name": "NetShield Dashboard",
    "description": "Colección completa de la API de NetShield Dashboard.\n\nEntornos disponibles:\n- **Local Mock**: servidor corriendo con MOCK_ALL=true (sin infraestructura externa)\n- **Local Real**: servidor corriendo contra servicios reales de laboratorio\n- **Lab (remoto)**: servidor corriendo en el equipo del laboratorio\n\nWebSockets documentados al final de cada módulo (usar Postman WS o wscat).",
    "_postman_id": "netshield-2026-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "ws_url",   "value": "ws://localhost:8000" }
  ],
  "item": [

    {
      "name": "🩺 Sistema",
      "item": [
        {
          "name": "Health check",
          "request": { "method": "GET", "url": "{{base_url}}/api/health" }
        },
        {
          "name": "Mock status",
          "request": { "method": "GET", "url": "{{base_url}}/api/system/mock-status" }
        },
        {
          "name": "Action log history",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/actions/history?limit=50",
              "query": [{ "key": "limit", "value": "50" }]
            }
          }
        }
      ]
    },

    {
      "name": "🔴 MikroTik",
      "item": [
        {
          "name": "Interfaces",
          "request": { "method": "GET", "url": "{{base_url}}/api/mikrotik/interfaces" }
        },
        {
          "name": "Conexiones activas",
          "request": { "method": "GET", "url": "{{base_url}}/api/mikrotik/connections" }
        },
        {
          "name": "Tabla ARP",
          "request": { "method": "GET", "url": "{{base_url}}/api/mikrotik/arp" }
        },
        {
          "name": "Buscar en ARP",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/mikrotik/arp/search?q=192.168",
              "query": [{ "key": "q", "value": "192.168" }]
            }
          }
        },
        {
          "name": "Tráfico por interfaz",
          "request": { "method": "GET", "url": "{{base_url}}/api/mikrotik/traffic" }
        },
        {
          "name": "Tráfico todas las interfaces",
          "request": { "method": "GET", "url": "{{base_url}}/api/mikrotik/interfaces/traffic/all" }
        },
        {
          "name": "Reglas de firewall",
          "request": { "method": "GET", "url": "{{base_url}}/api/mikrotik/firewall/rules" }
        },
        {
          "name": "Bloquear IP",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/mikrotik/firewall/block",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"ip\": \"203.0.113.45\", \"comment\": \"Test block\", \"list\": \"Blacklist_Automatica\"}"
            }
          }
        },
        {
          "name": "Desbloquear IP",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/mikrotik/firewall/block?ip=203.0.113.45",
              "query": [{ "key": "ip", "value": "203.0.113.45" }]
            }
          }
        },
        {
          "name": "Logs del sistema",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/mikrotik/logs?limit=20",
              "query": [{ "key": "limit", "value": "20" }]
            }
          }
        },
        {
          "name": "Health MikroTik",
          "request": { "method": "GET", "url": "{{base_url}}/api/mikrotik/health" }
        },
        {
          "name": "WS: Tráfico en tiempo real",
          "request": {
            "method": "GET",
            "url": "{{ws_url}}/ws/traffic",
            "description": "WebSocket. Usar: wscat -c {{ws_url}}/ws/traffic\nEmite cada 2s: {type: 'traffic', data: {interfaces:[...], active_connections: N}}"
          }
        }
      ]
    },

    {
      "name": "🔵 VLANs",
      "item": [
        {
          "name": "Listar VLANs",
          "request": { "method": "GET", "url": "{{base_url}}/api/mikrotik/vlans/" }
        },
        {
          "name": "Crear VLAN",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/mikrotik/vlans/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"vlan_id\": 50, \"name\": \"vlan50\", \"interface\": \"bridge\", \"comment\": \"VLAN de prueba\"}"
            }
          }
        },
        {
          "name": "Actualizar VLAN",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/mikrotik/vlans/*A",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\"comment\": \"VLAN Docentes — actualizado\"}"
            }
          }
        },
        {
          "name": "Eliminar VLAN",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/mikrotik/vlans/*A"
          }
        },
        {
          "name": "Tráfico todas las VLANs",
          "request": { "method": "GET", "url": "{{base_url}}/api/mikrotik/vlans/traffic/all" }
        },
        {
          "name": "Tráfico VLAN específica",
          "request": { "method": "GET", "url": "{{base_url}}/api/mikrotik/vlans/10/traffic" }
        },
        {
          "name": "Alertas de VLAN específica",
          "request": { "method": "GET", "url": "{{base_url}}/api/mikrotik/vlans/10/alerts" }
        },
        {
          "name": "WS: Tráfico VLANs en tiempo real",
          "request": {
            "method": "GET",
            "url": "{{ws_url}}/ws/vlans/traffic",
            "description": "WebSocket. Emite cada 2s: {type: 'vlan_traffic', data: {vlans:[...], timestamp:'...'}}"
          }
        }
      ]
    },

    {
