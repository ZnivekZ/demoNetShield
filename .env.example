# NetShield Dashboard — Variables de Entorno
# ================================================
# Copiar este archivo a backend/.env y completar con valores reales.
# NUNCA commitear el archivo .env con credenciales reales.

# ── MikroTik CHR ──────────────────────────────────────────────────
# Router MikroTik Cloud Hosted Router accesible via API RouterOS
MIKROTIK_HOST=192.168.100.118        # IP del MikroTik CHR en la red local
MIKROTIK_PORT=8728                   # Puerto API RouterOS (default 8728, no SSL)
MIKROTIK_USER=admin                  # Usuario con permisos de lectura/escritura en RouterOS
MIKROTIK_PASSWORD=tu_password_aqui   # Contraseña del usuario RouterOS

# ── Wazuh SIEM ────────────────────────────────────────────────────
# Servidor Wazuh Manager con API REST habilitada
WAZUH_HOST=100.90.106.121            # IP del Wazuh Manager (puede ser IP Tailscale)
WAZUH_PORT=55000                     # Puerto API REST de Wazuh (default 55000)
WAZUH_USER=wazuh                     # Usuario API de Wazuh (creado en Security > Users)
WAZUH_PASSWORD=tu_password_aqui      # Contraseña del usuario API

# ── Anthropic Claude AI ───────────────────────────────────────────
# Se usa para generación de reportes de seguridad con IA
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx  # API key de Anthropic (solo necesaria para reportes)

# ── Base de Datos ─────────────────────────────────────────────────
# SQLite para laboratorio, PostgreSQL para producción
# SQLite:     sqlite+aiosqlite:///./netshield.db
# PostgreSQL: postgresql+asyncpg://usuario:password@host:5432/netshield
DATABASE_URL=sqlite+aiosqlite:///./netshield.db

# ── Redis (opcional) ──────────────────────────────────────────────
# Cache para métricas de tiempo real. No implementado aún.
# El sistema funciona sin Redis.
REDIS_URL=redis://localhost:6379

# ── Configuración de Aplicación ───────────────────────────────────
# Entorno: "development" habilita Swagger UI, SQL echo, y hot reload
# Nivel de log: DEBUG, INFO, WARNING, ERROR
APP_ENV=development
LOG_LEVEL=DEBUG

# ── CORS ──────────────────────────────────────────────────────────
# Orígenes permitidos para el frontend (JSON array o lista separada por comas)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
