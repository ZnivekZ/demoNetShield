        {
          "name": "Timeline de alertas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/wazuh/alerts/timeline?level_min=5&minutes=60",
              "query": [
                { "key": "level_min", "value": "5" },
                { "key": "minutes", "value": "60" }
