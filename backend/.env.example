# NetShield Dashboard - Environment Variables
# ================================================
# Copy this file to .env and fill in real values

# MikroTik CHR API
MIKROTIK_HOST=192.168.100.118
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=nivek

# Wazuh SIEM API
WAZUH_HOST=100.90.106.121
WAZUH_PORT=55000
WAZUH_USER=admin
WAZUH_PASSWORD=admin

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Database (SQLite for lab, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./netshield.db

# Redis (optional - system works without it)
REDIS_URL=redis://localhost:6379

# App Settings
APP_ENV=development
LOG_LEVEL=DEBUG
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# GLPI (Asset Management / Inventario)
GLPI_URL=http://glpi.facultad.local
GLPI_APP_TOKEN=
GLPI_USER_TOKEN=
GLPI_VERIFY_SSL=false

# ── Mock Mode ───────────────────────────────────────────────────────────────
# Activa datos simulados sin necesitar sistemas externos corriendo.
#
# Modos disponibles:
#   MOCK_ALL=true        → todos los servicios en mock (modo demo completo)
#   MOCK_MIKROTIK=true   → solo MikroTik en mock, el resto real
#   MOCK_WAZUH=true      → solo Wazuh en mock, el resto real
#   MOCK_GLPI=true       → solo GLPI en mock, el resto real
#   MOCK_ANTHROPIC=true  → solo Anthropic en mock, el resto real
#
# Combinación: MOCK_ALL activa todo; los flags individuales son OR sobre MOCK_ALL.
# Híbrido: MOCK_ALL=false + MOCK_GLPI=true → GLPI mock, MikroTik/Wazuh reales.
#
# Retrocompat: APP_ENV=lab sin ninguna variable MOCK_* definida = MOCK_ALL=true
# Para usar APP_ENV=lab con servicios reales: agregar MOCK_ALL=false explícitamente.
#
MOCK_ALL=false
# MOCK_MIKROTIK=false
# MOCK_WAZUH=false
# MOCK_GLPI=false
# MOCK_ANTHROPIC=false
# MOCK_CROWDSEC=false   # false = intenta conectar al CrowdSec real

# ── CrowdSec IPS (Collaborative Security) ─────────────────────────────────
# Para activar CrowdSec real:
#   1. Instalar CrowdSec en el servidor
#   2. Registrar el bouncer de MikroTik con "cscli bouncers add netshield-bouncer"
#   3. Completar CROWDSEC_URL y CROWDSEC_API_KEY
#   4. Cambiar MOCK_CROWDSEC=false (o no definirla, si MOCK_ALL=false)
CROWDSEC_URL=http://localhost:8080
CROWDSEC_API_KEY=

# ── GeoIP (Geolocalización local de IPs) ───────────────────────────────
# Base de datos MaxMind GeoLite2 para geolocalización local sin API externa.
# Descargar: python backend/scripts/download_geoip.py
# Registro gratuito en: https://www.maxmind.com/en/geolite2/signup
#
# MOCK_GEOIP=true  → usa datos simulados (por defecto, hasta descargar la DB)
# MOCK_GEOIP=false → requiere las DBs .mmdb descargadas en las rutas indicadas
GEOIP_CITY_DB=backend/data/geoip/GeoLite2-City.mmdb
GEOIP_ASN_DB=backend/data/geoip/GeoLite2-ASN.mmdb
MAXMIND_LICENSE_KEY=
MOCK_GEOIP=true

# ── Suricata IDS/IPS/NSM ─────────────────────────────────────────────────
# Motor de análisis de red (IDS/IPS/NSM).
# Flujo real: tráfico → Suricata → eve.json → Agente Wazuh → Wazuh Manager → NetShield
# Control del motor via Unix socket en el host donde corre Suricata.
#
# Para activar Suricata real:
#   1. Instalar Suricata: apt install suricata
#   2. Configurar el agente Wazuh en el mismo host para leer eve.json
#   3. Asegurar que el usuario del backend puede leer el socket (grupo suricata)
#   4. Cambiar MOCK_SURICATA=false
#
# MOCK_SURICATA=true  → datos simulados (por defecto hasta instalación)
# MOCK_SURICATA=false → requiere Suricata corriendo + socket accesible
SURICATA_SOCKET=/var/run/suricata/suricata.socket
SURICATA_EVE_LOG=/var/log/suricata/eve.json
SURICATA_HOST=192.168.88.50
MOCK_SURICATA=true

# ── Telegram Bot (Notificaciones Bidireccionales) ──────────────────────────
# Bot de Telegram para alertas outbound y consultas inbound via IA.
# Crear bot: https://core.telegram.org/bots#botfather → /newbot
# Obtener chat_id: enviar un mensaje al bot y consultar
#   https://api.telegram.org/bot<TOKEN>/getUpdates
#
# MOCK_TELEGRAM=true  → datos simulados (por defecto, hasta configurar bot)
# MOCK_TELEGRAM=false → requiere token válido y chat_id configurado
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_IDS=
MOCK_TELEGRAM=true
